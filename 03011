#include <iostream>
#include <ctime>
using namespace std;

void printArray(int arr[], int n)
{
    for(int i=0; i<n; i++)
        cout << arr[i] << " ";
    cout << endl;
}

void bubbleSortSteps(int arr[], int n)
{
    cout << "\nBubble Sort Steps:\n";
    for(int i=0; i<n-1; i++)
    {
        for(int j=0; j<n-i-1; j++)
        {
            if(arr[j] > arr[j+1])
                swap(arr[j], arr[j+1]);
        }
        cout << "Pass " << i+1 << ": ";
        printArray(arr, n);
    }
}

void insertionSortSteps(int arr[], int n)
{
    cout << "\nInsertion Sort Steps:\n";
    for(int i=1; i<n; i++)
    {
        int key = arr[i];
        int j = i-1;
        while(j >= 0 && arr[j] > key)
        {
            arr[j+1] = arr[j];
            j--;
        }
        arr[j+1] = key;
        cout << "Step " << i << ": ";
        printArray(arr, n);
    }
}

void merge(int arr[], int l, int m, int r, int n)
{
    int i = l, j = m+1, k = 0;
    int temp[100];

    while(i <= m && j <= r)
    {
        if(arr[i] < arr[j])
            temp[k++] = arr[i++];
        else
            temp[k++] = arr[j++];
    }
    while(i <= m) temp[k++] = arr[i++];
    while(j <= r) temp[k++] = arr[j++];

    for(i = l, k = 0; i <= r; i++, k++)
        arr[i] = temp[k];

    cout << "Merge Step: ";
    printArray(arr, n);
}

void mergeSort(int arr[], int l, int r, int n)
{
    if(l < r)
    {
        int m = (l + r) / 2;
        mergeSort(arr, l, m, n);
        mergeSort(arr, m+1, r, n);
        merge(arr, l, m, r, n);
    }
}

int partition(int arr[], int low, int high, int n)
{
    int pivot = arr[high];
    int i = low - 1;
    for(int j = low; j < high; j++)
    {
        if(arr[j] < pivot)
        {
            i++;
            swap(arr[i], arr[j]);
        }
    }
    swap(arr[i+1], arr[high]);
    cout << "Partition Step: ";
    printArray(arr, n);
    return i+1;
}

void quickSort(int arr[], int low, int high, int n)
{
    if(low < high)
    {
        int pi = partition(arr, low, high, n);
        quickSort(arr, low, pi-1, n);
        quickSort(arr, pi+1, high, n);
    }
}

int main()
{
    int demo[] = {5, 3, 8, 4, 2};
    int n = 5;

    cout << "Original Array:\n";
    printArray(demo, n);

    int a[5], b[5], c[5], d[5];
    for(int i=0; i<n; i++)
        a[i] = b[i] = c[i] = d[i] = demo[i];

    // Bubble Sort steps + timing
    clock_t start = clock();
    bubbleSortSteps(a, n);
    clock_t end = clock();
    double time_bubble = double(end - start) / CLOCKS_PER_SEC;

    // Insertion Sort steps + timing
    start = clock();
    insertionSortSteps(b, n);
    end = clock();
    double time_insertion = double(end - start) / CLOCKS_PER_SEC;

    // Merge Sort steps + timing
    start = clock();
    cout << "\nMerge Sort Steps:\n";
    mergeSort(c, 0, n-1, n);
    cout << "Final Merge Sort Result: ";
    printArray(c, n);
    end = clock();
    double time_merge = double(end - start) / CLOCKS_PER_SEC;

    // Quick Sort steps + timing
    start = clock();
    cout << "\nQuick Sort Steps:\n";
    quickSort(d, 0, n-1, n);
    cout << "Final Quick Sort Result: ";
    printArray(d, n);
    end = clock();
    double time_quick = double(end - start) / CLOCKS_PER_SEC;

    // 印時間（小數點）
    cout << "\n\n===== Empirical Time Test (seconds) =====\n";
    cout << "Bubble Sort Time: " << time_bubble << " sec\n";
    cout << "Insertion Sort Time: " << time_insertion << " sec\n";
    cout << "Merge Sort Time: " << time_merge << " sec\n";
    cout << "Quick Sort Time: " << time_quick << " sec\n";

    return 0;
}
